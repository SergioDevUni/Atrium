# Atrium can run without an AI key using fallback behavior.
# Add one provider for live AI responses.

# Google Studio / Gemini
GOOGLE_API_KEY=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite

# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-3.1-flash-lite
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_APP_NAME=Atrium
