# Copy this file to .env.production on the VPS.
# Do not commit the real .env.production file.

# Domain handled by Caddy. Use one domain or comma-separated hostnames.
# Example: DOMAIN=atrium.example.com
DOMAIN=localhost

# PM2 process settings inside the app container.
PM2_INSTANCES=1
PM2_EXEC_MODE=fork
PM2_MAX_MEMORY_RESTART=512M

# Simple access gate. Override these in production.
ATRIUM_LOGIN_USER=atrium
ATRIUM_LOGIN_PASSWORD=workgate
ATRIUM_AUTH_TOKEN=atrium-local-session

# Google Studio / Gemini
GOOGLE_API_KEY=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite

# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-3.1-flash-lite
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_APP_NAME=Atrium
